# ─── Collection Settings ────────────────────────────────────────────────────
WORKERS=6
HEADLESS=true
CHECKPOINT_INTERVAL=50
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# ─── Timeouts ────────────────────────────────────────────────────────────────
PAGE_TIMEOUT_MS=30000
SCREENSHOT_TIMEOUT_MS=15000
NETWORK_IDLE_TIMEOUT_MS=10000

# ─── Paths ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=./dataset
CHECKPOINT_DIR=./checkpoints
LOGS_DIR=./logs
METADATA_DIR=./metadata
REPORTS_DIR=./reports
URL_DIR=./url

# ─── CSV Selection ───────────────────────────────────────────────────────────
# Specify a filename to prefer when multiple CSVs exist in URL_DIR.
# The reduced selected_dataset.csv is auto-selected when present.
# CSV_FILE=selected_dataset.csv

# ─── Dataset Split ────────────────────────────────────────────────────────────
SPLIT_TRAIN=0.70
SPLIT_VAL=0.15
SPLIT_TEST=0.15

# ─── Image Quality ───────────────────────────────────────────────────────────
MIN_WIDTH=100
MIN_HEIGHT=100
MAX_BLANK_RATIO=0.98
DUPLICATE_HASH_THRESHOLD=10

# ─── Anti-Detection ──────────────────────────────────────────────────────────
ANTI_DETECTION=true

# ─── Limits (0 = no limit) ───────────────────────────────────────────────────
# Process only the first N URLs (useful for testing)
MAX_URLS=0
# Only process phishing (1), legitimate (0), or both (-1)
LABEL_FILTER=-1

# ─── Screenshot capture ──────────────────────────────────────────────────────
# New strategy: one desktop screenshot per page type.
# Mobile / fullpage / above-fold variants are disabled by default.
CAPTURE_DESKTOP=true
CAPTURE_MOBILE=false
CAPTURE_FULLPAGE=false
CAPTURE_ABOVEFOLD=false

# ─── Page discovery ──────────────────────────────────────────────────────────
# Controls which secondary page types are discovered and captured per URL.
# Discovered pages are always deduplicated by final URL and content hash.
DISCOVER_LOGIN=true
DISCOVER_SIGNUP=true
DISCOVER_FORGOT_PASSWORD=true
DISCOVER_CHECKOUT=true
DISCOVER_PAYMENT=true
DISCOVER_ACCOUNT=true
DISCOVER_PROFILE=true
DISCOVER_DASHBOARD=true
