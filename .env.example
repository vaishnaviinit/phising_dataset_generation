# ─── Collection Settings ────────────────────────────────────────────────────
WORKERS=6
HEADLESS=true
CHECKPOINT_INTERVAL=50
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# ─── Timeouts ────────────────────────────────────────────────────────────────
PAGE_TIMEOUT_MS=30000
SCREENSHOT_TIMEOUT_MS=15000
NETWORK_IDLE_TIMEOUT_MS=10000

# ─── Paths ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=./dataset
CHECKPOINT_DIR=./checkpoints
LOGS_DIR=./logs
METADATA_DIR=./metadata
REPORTS_DIR=./reports
URL_DIR=./url

# ─── CSV Selection ───────────────────────────────────────────────────────────
# If multiple CSVs exist in URL_DIR, specify one here (filename only)
# CSV_FILE=Dataset.csv

# ─── Dataset Split ────────────────────────────────────────────────────────────
SPLIT_TRAIN=0.70
SPLIT_VAL=0.15
SPLIT_TEST=0.15

# ─── Image Quality ───────────────────────────────────────────────────────────
MIN_WIDTH=100
MIN_HEIGHT=100
MAX_BLANK_RATIO=0.98
DUPLICATE_HASH_THRESHOLD=10

# ─── Anti-Detection ──────────────────────────────────────────────────────────
ANTI_DETECTION=true

# ─── Limits (0 = no limit) ───────────────────────────────────────────────────
# Useful for testing: only process first N URLs
MAX_URLS=0
# Only process phishing (1), legitimate (0), or both (-1)
LABEL_FILTER=-1

# ─── Screenshot Types ────────────────────────────────────────────────────────
CAPTURE_DESKTOP=true
CAPTURE_MOBILE=true
CAPTURE_FULLPAGE=true
CAPTURE_ABOVEFOLD=true
